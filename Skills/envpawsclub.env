# --- CAL.COM API CONFIGURATION ---
CAL_API_KEY="tu_api_key_aqui" # Obtenla en cal.com/settings/developer/api-keys
CAL_API_BASE_URL="https://api.cal.com/v1"

# --- EVENT TYPES (IDS DE PAWS CLUB) ---
# Sustituye estos IDs con los que aparecen en la URL de edición de tus eventos en Cal.com
CAL_EVENT_ID_NORTE="123456" 
CAL_EVENT_ID_PONIENTE="789012"
CAL_EVENT_ID_DOMICILIO="345678"

# --- BUSINESS LOGIC SETTINGS ---
PAWS_MIN_BUFFER_MINUTES=15
PAWS_TIMEZONE="America/Mexico_City"
PAWS_DEFAULT_DURATION=60

# --- WEBHOOK SECRET (OPCIONAL PARA NOTIFICACIONES) ---
CAL_WEBHOOK_SECRET="tu_secreto_para_validar_respuestas"